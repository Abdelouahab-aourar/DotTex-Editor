{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "fs:allow-app-read-recursive",
    "fs:allow-exists",
    "fs:allow-app-write",
    "fs:allow-app-read",
    {
      "identifier": "fs:allow-desktop-read-recursive",
      "comment": "Allows recursive access if folders are on the desktop"
    },
    {
      "identifier": "fs:allow-home-read-recursive",
      "comment": "Allows reading subfolders nested deeply within the home directory"
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "name": "binaries/texlab",
          "sidecar": true
        }
      ]
    },
    "fs:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/*"
        }
      ]
    },
    "dialog:default"
  ]
}